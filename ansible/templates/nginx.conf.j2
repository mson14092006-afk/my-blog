server {

    # Nginx lắng nghe HTTP request ở port 80
    # Người dùng truy cập: http://<domain name> hoặc http://<IP>
    listen 80;


    # Domain hoặc IP mà server block này xử lý
    server_name 192.168.122.100;


    # Xử lý tất cả request có URL bắt đầu bằng "/"
    # Ví dụ:
    # GET /
    # GET /posts
    # GET /login
    location / {
	# Client -> Nginx :80 -> Flask :5000
        proxy_pass http://127.0.0.1:5000;
        # Gửi hostname (domain name) ban đầu mà client truy cập
        proxy_set_header Host $host;
        # Gửi IP thật của client cho Flask
        proxy_set_header X-Real-IP $remote_addr;
        # Lưu lại danh sách proxy mà request đã đi qua
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # Cho Flask biết giao thức ban đầu của client
        # User -HTTPS->Nginx-HTTP->Flask
        proxy_set_header X-Forwarded-Proto $scheme;

    }
}
